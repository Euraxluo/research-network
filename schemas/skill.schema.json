{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Skill Manifest",
  "type": "object",
  "required": [
    "schema",
    "name",
    "version",
    "description",
    "capabilities",
    "relation"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "research-skill/v0.1"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relation": {
      "enum": [
        "owned",
        "forked",
        "dependency",
        "referenced",
        "vendored"
      ]
    },
    "derived_from": {
      "type": [
        "object",
        "null"
      ]
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "entry": {
      "type": "string",
      "default": "SKILL.md"
    },
    "access": {
      "type": "object",
      "properties": {
        "visibility": {
          "enum": [
            "public",
            "encrypted",
            "private_delegation"
          ]
        },
        "seal_id": {
          "type": "string"
        },
        "walrus_blob_id": {
          "type": "string"
        },
        "ciphertext_hash": {
          "type": "string"
        },
        "plaintext_commitment": {
          "type": "string"
        },
        "required_tier": {
          "type": "number"
        },
        "free_preview": {
          "type": "string"
        }
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
