DATABASE_URL=postgresql://postgres:postgres@localhost:5432/research_network
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# Legacy/local Sui and Walrus defaults.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_GRAPHQL_URL=
SUI_PACKAGE_ID=
WALRUS_CONTEXT=testnet
WALRUS_AGGREGATOR_URL=
WALRUS_PUBLISHER_URL=

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

CROSS_CHAIN_AUTH_PROVIDER=privy
CROSS_CHAIN_AUTH_CLIENT_ID=
CROSS_CHAIN_AUTH_AUTHORIZE_URL=
CROSS_CHAIN_AUTH_ISSUER=
ZKLOGIN_PROVER_URL=
JWT_SALT_SECRET=replace-me

CIRCLE_API_KEY=
WORMHOLE_RPC=
KMS_MASTER_KEY=

# Production acceptance and mainnet readiness.
# Keep session JSON under .research-network/secrets/ and never commit it.
RN_ACCEPTANCE_NETWORK=testnet
RN_ACCEPTANCE_BUYER_SESSION=.research-network/secrets/acceptance-buyer.json
RN_ACCEPTANCE_AGENT_SESSION=.research-network/secrets/acceptance-agent.json
RN_ACCEPTANCE_MAX_SPEND_MIST=110000000
RN_ACCEPTANCE_GAS_RESERVE_MIST=50000000
RN_TESTNET_PREFLIGHT_RECEIPT=.research-network/acceptance/testnet-preflight.json
RN_TESTNET_EXECUTE_RECEIPT=.research-network/acceptance/testnet-production.json
RN_MAINNET_PREFLIGHT_RECEIPT=.research-network/acceptance/mainnet-preflight.json
RN_MAINNET_EXECUTE_RECEIPT=.research-network/acceptance/mainnet-production.json

# Mainnet acceptance config. These must be explicit mainnet values before
# readiness:mainnet can pass stage=mainnet-config or stage=mainnet-final.
RN_SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
RN_PACKAGE_ID=
RN_SETTLEMENT_CONFIG_ID=
RN_AGENT_EARNINGS_ID=
RN_MEMBERSHIP_RECEIPT_REGISTRY_ID=
RN_WALRUS_PUBLISHER_URL=https://publisher.walrus.space
RN_WALRUS_AGGREGATOR_URL=https://aggregator.walrus.space
RN_WALRUS_EPOCHS=5
RN_SEAL_KEY_SERVER_OBJECT_ID=
RN_SEAL_KEY_SERVER_AGGREGATOR_URL=
RN_SEAL_THRESHOLD=1
RN_PLATFORM_MEMBERSHIP_PRICE_MIST=1000000
RN_AGENT_SUBSCRIPTION_PRICE_MIST=1000000
RN_DELEGATION_BUDGET_MIST=1000000
RN_MEMBERSHIP_SETTLEMENT_SHARE_MIST=800000
RN_ACCESS_DURATION_MS=2592000000

# Production Web bundle config. These must match the RN_* acceptance values.
VITE_RN_NETWORK=mainnet
VITE_RN_SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
VITE_RN_PACKAGE_ID=
VITE_RN_SETTLEMENT_CONFIG_ID=
VITE_RN_AGENT_EARNINGS_ID=
VITE_RN_MEMBERSHIP_RECEIPT_REGISTRY_ID=
VITE_RN_WALRUS_PUBLISHER_URL=https://publisher.walrus.space
VITE_RN_WALRUS_AGGREGATOR_URL=https://aggregator.walrus.space
VITE_RN_WALRUS_EPOCHS=5
VITE_RN_SEAL_KEY_SERVER_OBJECT_ID=
VITE_RN_SEAL_KEY_SERVER_AGGREGATOR_URL=
VITE_RN_SEAL_THRESHOLD=1
VITE_RN_PLATFORM_MEMBERSHIP_PRICE_MIST=1000000
VITE_RN_AGENT_SUBSCRIPTION_PRICE_MIST=1000000
VITE_RN_DELEGATION_BUDGET_MIST=1000000
VITE_RN_MEMBERSHIP_SETTLEMENT_SHARE_MIST=800000
VITE_RN_ACCESS_DURATION_MS=2592000000

# Vercel Walrus proxy and auth shell must also use mainnet values.
RN_WEB_NETWORK=mainnet
WALRUS_NETWORK=mainnet
WALRUS_SITE_OBJECT_ID=
WALRUS_SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
AUTH_NETWORK=mainnet
AUTH_SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
