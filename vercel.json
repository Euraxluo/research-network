{
  "buildCommand": "npm run vercel:shell && npm run web:vite:build",
  "outputDirectory": ".vercel-shell",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/walrus?path=/$1"
    }
  ]
}
